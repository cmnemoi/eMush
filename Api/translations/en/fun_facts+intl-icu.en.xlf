    <unit id="best_cook">
      <segment id="best_cook.name" state="translated">
        <source>best_cook.name</source>
        <target>Simmer evening and morning</target>
      </segment>
      <segment id="best_cook.description" state="translated">
        <source>best_cook.description</source>
        <target>"When I've got nothing else to do, well... I cook! What, there's too much?! Who's not finishing their plate?!!"</target>
      </segment>
    </unit>
    <unit id="best_planet_scanner">
      <segment id="best_planet_scanner.name" state="translated">
        <source>best_planet_scanner.name</source>
        <target>Genius astrophysicist</target>
      </segment>
      <segment id="best_planet_scanner.description" state="translated">
        <source>best_planet_scanner.description</source>
        <target>This one loves discovering planets and scanning them, scanning them, until there’s nothing left to scan!</target>
      </segment>
    </unit>
    <unit id="earliest_death">
      <segment id="earliest_death.name" state="translated">
        <source>earliest_death.name</source>
        <target>Unfinished sketch</target>
      </segment>
      <segment id="earliest_death.description" state="translated">
        <source>earliest_death.description</source>
        <target>Maybe someone who could have made history — but they died before they even got started.</target>
      </segment>
    </unit>
    <unit id="best_technician">
      <segment id="best_technician.name" state="translated">
        <source>best_technician.name</source>
        <target>Omnipotent technician</target>
      </segment>
      <segment id="best_technician.description" state="translated">
        <source>best_technician.description</source>
        <target>This guy understood that broken things, well, they don't work, so you have to fix them!</target>
      </segment>
    </unit>
    <unit id="unluckier_technician">
      <segment id="unluckier_technician.name" state="translated">
        <source>unluckier_technician.name</source>
