    <unit id="best_cook">
      <segment id="best_cook.name" state="translated">
        <source>best_cook.name</source>
        <target>Mitonne soir et matin</target>
      </segment>
      <segment id="best_cook.description" state="translated">
        <source>best_cook.description</source>
        <target>« Quand j'ai rien d'autre à faire, eh ben... J'cuisine ! Quoi, y'en a trop ?! Qui finit pas son assiette ?!! »</target>
      </segment>
    </unit>
