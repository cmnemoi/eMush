      </segment>
      <segment id="sol_collabs.description" state="translated">
        <source>sol_collabs.description</source>
        <target>Here's someone who understood the usefulness of establishing the radio link from the communication terminal.</target>
      </segment>
    </unit>
    <unit id="best_caresser">
      <segment id="best_caresser.name" state="translated">
        <source>best_caresser.name</source>
        <target>Cat hair addict</target>
      </segment>
      <segment id="best_caresser.description" state="translated">
        <source>best_caresser.description</source>
        <target>It was nice to cuddle the cat, but that's not supposed to be the main objective of the trip...
</target>
      </segment>
    </unit>
    <unit id="best_hunter_killer">
      <segment id="best_hunter_killer.name" state="translated">
        <source>best_hunter_killer.name</source>
        <target>Battlestar-class pilot</target>
      </segment>
      <segment id="best_hunter_killer.description" state="translated">
        <source>best_hunter_killer.description</source>
        <target>Worthy incarnation of Starbuck the heroine, devastating destroyer of enemy space dishes!</target>
      </segment>
    </unit>
    <unit id="best_lost">
      <segment id="best_lost.name" state="translated">
        <source>best_lost.name</source>
        <target>"I shouldn't have come."</target>
      </segment>
      <segment id="best_lost.description" state="translated">
        <source>best_lost.description</source>
        <target>They came, got lost, waited... loooong time..., and they could have stayed there.</target>
      </segment>
    </unit>
    <unit id="best_killer">
      <segment id="best_killer.name" state="translated">
        <source>best_killer.name</source>
        <target>Compulsive assassin</target>
      </segment>
      <segment id="best_killer.description" state="translated">
        <source>best_killer.description</source>
        <target>If they could have eaten his teammates, they might have done it. With salt on the side.</target>
      </segment>
    </unit>
