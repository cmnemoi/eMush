    <unit id="sol_return">
      <segment id="name" state="translated">
        <source>sol_return.name</source>
        <target>El Daedalus regresó a Sol</target>
      </segment>
      <segment id="short_name" state="translated">
        <source>sol_return.short_name</source>
        <target>¡El Daedalus regresó a Sol!</target>
      </segment>
      <segment id="category" state="translated">
        <source>sol_return.category</source>
        <target>Has regresado a Sol... ¡Pero el resto es otra historia!</target>
      </segment>
      <segment id="description" state="translated">
        <source>sol_return.description</source>
        <target>Has decidido intentar regresar a Sol. Tu loca aventura en el Daedalus termina aquí. ¿Será que ahora eres una legenda?</target>
      </segment>
    </unit>
    <unit id="eden">
      <segment id="name" state="translated">
        <source>eden.name</source>
        <target>El Daedalus se asentó en Edén</target>
      </segment>
      <segment id="short_name" state="translated">
        <source>eden.short_name</source>
        <target>¡El Daedalus aterrizó en Edén!</target>
      </segment>
      <segment id="category" state="translated">
        <source>eden.category</source>
        <target>Después de todas estas andanzas, has emprendido tu camino a Edén... ¡Pero el resto es otra historia!</target>
      </segment>
      <segment id="description" state="translated">
        <source>eden.description</source>
        <target>De la escoria de la humanidad surge la esperanza En un nuevo planeta, un nuevo comienzo y la continuación de las aventuras de nuestros héroes. Pero esta es otra historia.</target>
      </segment>
    </unit>
    <unit id="daedalus_destroyed">
