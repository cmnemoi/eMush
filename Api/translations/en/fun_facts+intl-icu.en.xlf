<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0" srcLang="en" trgLang="en">
  <file id="fun_facts.ext">
    <unit id="best_cook">
      <segment id="best_cook.name" state="translated">
        <source>best_cook.name</source>
        <target>Simmer evening and morning</target>
      </segment>
      <segment id="best_cook.description" state="translated">
        <source>best_cook.description</source>
        <target>"When I've got nothing else to do, well... I cook! What, there's too much?! Who's not finishing their plate?!!"</target>
      </segment>
    </unit>
    <unit id="best_planet_scanner">
      <segment id="best_planet_scanner.name" state="translated">
        <source>best_planet_scanner.name</source>
        <target>Genius astrophysicist</target>
      </segment>
      <segment id="best_planet_scanner.description" state="translated">
        <source>best_planet_scanner.description</source>
        <target>This one loves discovering planets and scanning them, scanning them, until there’s nothing left to scan!</target>
      </segment>
    </unit>
    <unit id="earliest_death">
      <segment id="earliest_death.name" state="translated">
        <source>earliest_death.name</source>
        <target>Unfinished sketch</target>
      </segment>
      <segment id="earliest_death.description" state="translated">
        <source>earliest_death.description</source>
        <target>Maybe someone who could have made history — but they died before they even got started.</target>
      </segment>
    </unit>
    <unit id="best_technician">
      <segment id="best_technician.name" state="translated">
        <source>best_technician.name</source>
        <target>Omnipotent technician</target>
      </segment>
      <segment id="best_technician.description" state="translated">
        <source>best_technician.description</source>
        <target>This guy understood that broken things, well, they don't work, so you have to fix them!</target>
      </segment>
    </unit>
    <unit id="unluckier_technician">
      <segment id="unluckier_technician.name" state="translated">
        <source>unluckier_technician.name</source>
        <target>Two-Left-Hands</target>
      </segment>
      <segment id="unluckier_technician.description" state="translated">
        <source>unluckier_technician.description</source>
        <target>Don't let them hold the wrench. They clearly can't do anything with it...</target>
      </segment>
    </unit>
    <unit id="sol_collabs">
      <segment id="sol_collabs.name" state="translated">
        <source>sol_collabs.name</source>
        <target>Radio Service assistant</target>
      </segment>
      <segment id="sol_collabs.description" state="translated">
        <source>sol_collabs.description</source>
        <target>Here's someone who understood the usefulness of establishing the radio link from the communication terminal.</target>
      </segment>
    </unit>
    <unit id="best_caresser">
      <segment id="best_caresser.name" state="translated">
        <source>best_caresser.name</source>
        <target>Cat hair addict</target>
      </segment>
      <segment id="best_caresser.description" state="translated">
        <source>best_caresser.description</source>
        <target>It was nice to cuddle the cat, but that's not supposed to be the main objective of the trip...</target>
      </segment>
    </unit>
    <unit id="best_hunter_killer">
      <segment id="best_hunter_killer.name" state="translated">
        <source>best_hunter_killer.name</source>
        <target>Battlestar-class pilot</target>
      </segment>
      <segment id="best_hunter_killer.description" state="translated">
        <source>best_hunter_killer.description</source>
        <target>Worthy incarnation of Starbuck the heroine, devastating destroyer of enemy space dishes!</target>
      </segment>
    </unit>
    <unit id="best_lost">
      <segment id="best_lost.name" state="translated">
        <source>best_lost.name</source>
        <target>"I shouldn't have come."</target>
      </segment>
      <segment id="best_lost.description" state="translated">
        <source>best_lost.description</source>
        <target>They came, got lost, waited... loooong time..., and they could have stayed there.</target>
      </segment>
    </unit>
    <unit id="best_killer">
      <segment id="best_killer.name" state="translated">
        <source>best_killer.name</source>
        <target>Compulsive assassin</target>
      </segment>
      <segment id="best_killer.description" state="translated">
        <source>best_killer.description</source>
        <target>If they could have eaten his teammates, they might have done it. With salt on the side.</target>
      </segment>
    </unit>
    <unit id="most_talkative">
      <segment id="most_talkative.name" state="translated">
        <source>most_talkative.name</source>
        <target>Talkative companion</target>
      </segment>
      <segment id="most_talkative.description" state="translated">
        <source>most_talkative.description</source>
        <target>The little voice heard day and night on the walkie-talkie. Goodbye loneliness!</target>
      </segment>
    </unit>
    <unit id="less_talkative">
      <segment id="less_talkative.name" state="translated">
        <source>less_talkative.name</source>
        <target>Radio silence mode</target>
      </segment>
      <segment id="less_talkative.description" state="translated">
        <source>less_talkative.description</source>
        <target>This one clearly never found the walkie-talkie button...</target>
      </segment>
    </unit>
    <unit id="less_active">
      <segment id="less_active.name" state="translated">
        <source>less_active.name</source>
        <target>Lazybones</target>
      </segment>
      <segment id="less_active.description" state="translated">
        <source>less_active.description</source>
        <target>Didn't bother much, even if it's the end of the world. No, for them, it's the others who work hard.</target>
      </segment>
    </unit>
    <unit id="most_active">
      <segment id="most_active.name" state="translated">
        <source>most_active.name</source>
        <target>Tireless hyperactive</target>
      </segment>
      <segment id="most_active.description" state="translated">
        <source>most_active.description</source>
        <target>They never stops and honestly, we wonder what they take to keep going...</target>
      </segment>
    </unit>
    <unit id="best_eater">
      <segment id="best_eater.name" state="translated">
        <source>best_eater.name</source>
        <target>When appetite goes...</target>
      </segment>
      <segment id="best_eater.description" state="translated">
        <source>best_eater.description</source>
        <target>Spends their time munching on everything they can get and even scrapes the bottom of the shelves.</target>
      </segment>
    </unit>
    <unit id="best_action_waster">
      <segment id="best_action_waster.name" state="translated">
        <source>best_action_waster.name</source>
        <target>Energy Waster</target>
      </segment>
      <segment id="best_action_waster.description" state="translated">
        <source>best_action_waster.description</source>
        <target>My motto? Waste lots of action points and enjoy the sun!</target>
      </segment>
    </unit>
    <unit id="worst_action_waster">
      <segment id="worst_action_waster.name" state="translated">
        <source>worst_action_waster.name</source>
        <target>SuperOptimizer</target>
      </segment>
      <segment id="worst_action_waster.description" state="translated">
        <source>worst_action_waster.description</source>
        <target>He almost never wasted an action point. Because he understood the goal of the game.</target>
      </segment>
    </unit>
    <unit id="best_sleeper">
      <segment id="best_sleeper.name" state="translated">
        <source>best_sleeper.name</source>
        <target>Lazy Sleeper</target>
      </segment>
      <segment id="best_sleeper.description" state="translated">
        <source>best_sleeper.description</source>
        <target>He spent the most time in bed. But only sleeping. Ahh...</target>
      </segment>
    </unit>
    <unit id="dead_during_sleep">
      <segment id="dead_during_sleep.name" state="translated">
        <source>dead_during_sleep.name</source>
        <target>Rest In Peace</target>
      </segment>
      <segment id="dead_during_sleep.description" state="translated">
        <source>dead_during_sleep.description</source>
        <target>Fire, asphyxiation, famine, betrayal, blind violence...? No, he died in his sleep.</target>
      </segment>
    </unit>
    <unit id="best_hacker">
      <segment id="best_hacker.name" state="translated">
        <source>best_hacker.name</source>
        <target>Anonymous Tinkerer</target>
      </segment>
      <segment id="best_hacker.description" state="translated">
        <source>best_hacker.description</source>
        <target>Lacking flashy titles, but resourceful! And access to the right terminals.</target>
      </segment>
    </unit>
    <unit id="best_com_technician">
      <segment id="best_com_technician.name" state="translated">
        <source>best_com_technician.name</source>
        <target>Dedicated Comm. Manager</target>
      </segment>
      <segment id="best_com_technician.description" state="translated">
        <source>best_com_technician.description</source>
        <target>Spent a lot of time and effort tinkering with the radio. You thanked him, at least?</target>
      </segment>
    </unit>
    <unit id="best_sandman">
      <segment id="best_sandman.name" state="translated">
        <source>best_sandman.name</source>
        <target>Walking Nightmare</target>
      </segment>
      <segment id="best_sandman.description" state="translated">
        <source>best_sandman.description</source>
        <target>Played too much Croquemonster and took pleasure in ruining his comrades' sleep.</target>
      </segment>
    </unit>
    <unit id="best_terrorist">
      <segment id="best_terrorist.name" state="translated">
        <source>best_terrorist.name</source>
        <target>Brutal Mutant Force</target>
      </segment>
      <segment id="best_terrorist.description" state="translated">
        <source>best_terrorist.description</source>
        <target>Terrifying brutal mutant terrorist, tireless and capable of giving you a hell of a beating!</target>
      </segment>
    </unit>
    <unit id="best_wounded">
      <segment id="best_wounded.name" state="translated">
        <source>best_wounded.name</source>
        <target>Unlucky and Helpless</target>
      </segment>
      <segment id="best_wounded.description" state="translated">
        <source>best_wounded.description</source>
        <target>Service wounded who only encounters unfair misfortunes... maybe shouldn't have gone unarmed?</target>
      </segment>
    </unit>
    <unit id="best_diseased">
      <segment id="best_diseased.name" state="translated">
        <source>best_diseased.name</source>
        <target>Frail Sickly</target>
      </segment>
      <segment id="best_diseased.description" state="translated">
        <source>best_diseased.description</source>
        <target>Incurable patient catching all the nasties going around. So don't expect too much from him.</target>
      </segment>
    </unit>
    <unit id="drug_addict">
      <segment id="drug_addict.name" state="translated">
        <source>drug_addict.name</source>
        <target>It's... just... recreational...</target>
      </segment>
      <segment id="drug_addict.description" state="translated">
        <source>drug_addict.description</source>
        <target>Heavy user of sketchy substances making him see laughing deer and sacred octopuses.</target>
      </segment>
    </unit>
    <unit id="knife_evader">
      <segment id="knife_evader.name" state="translated">
        <source>knife_evader.name</source>
        <target>Half Ninja Half Eel</target>
      </segment>
      <segment id="knife_evader.description" state="translated">
        <source>knife_evader.description</source>
        <target>Dodges blades like no one else, and no one can take him down. He's the ninja-eel man.</target>
      </segment>
    </unit>
    <unit id="best_agro">
      <segment id="best_agro.name" state="translated">
        <source>best_agro.name</source>
        <target>Dangerous Maniac</target>
      </segment>
      <segment id="best_agro.description" state="translated">
        <source>best_agro.description</source>
        <target>A super aggressive guy who attacks everything that moves. The terror of backyard chickens.</target>
      </segment>
    </unit>
    <unit id="worst_agro">
      <segment id="worst_agro.name" state="translated">
        <source>worst_agro.name</source>
        <target>Violence is Evil</target>
      </segment>
      <segment id="worst_agro.description" state="translated">
        <source>worst_agro.description</source>
        <target>Unconditional pacifist who harms almost no one. Others take care of it.</target>
      </segment>
    </unit>
    <unit id="lesser_drugged">
      <segment id="lesser_drugged.name" state="translated">
        <source>lesser_drugged.name</source>
        <target>Astonishing Purity</target>
      </segment>
      <segment id="lesser_drugged.description" state="translated">
        <source>lesser_drugged.description</source>
        <target>Drugs are bad, don't touch them kids. You don't touch them either, or I'll take you down.</target>
      </segment>
    </unit>
    <unit id="kube_addict">
      <segment id="kube_addict.name" state="translated">
        <source>kube_addict.name</source>
        <target>Useless Player</target>
      </segment>
      <segment id="kube_addict.description" state="translated">
        <source>kube_addict.description</source>
        <target>Addicted to mad'Kube, the thing that's useless. Why not take a tour on Galaxy 55 instead?...</target>
      </segment>
    </unit>
    <unit id="best_alien_traitor">
      <segment id="best_alien_traitor.name" state="translated">
        <source>best_alien_traitor.name</source>
        <target>Expedition Traitor</target>
      </segment>
      <segment id="best_alien_traitor.description" state="translated">
        <source>best_alien_traitor.description</source>
        <target>THE teammate no one should have ever brought to that cursed planet...</target>
      </segment>
    </unit>
    <unit id="stealthiest">
      <segment id="stealthiest.name" state="translated">
        <source>stealthiest.name</source>
        <target>Masked Sneak</target>
      </segment>
      <segment id="stealthiest.description" state="translated">
        <source>stealthiest.description</source>
        <target>The stealthy masked mushroom who committed the most sneaky actions in secret!</target>
      </segment>
    </unit>
    <unit id="unstealthiest">
      <segment id="unstealthiest.name" state="translated">
        <source>unstealthiest.name</source>
        <target>Discovered Mushroom</target>
      </segment>
      <segment id="unstealthiest.description" state="translated">
        <source>unstealthiest.description</source>
        <target>A not-so-discreet mushroom caught in the act. So what?</target>
      </segment>
    </unit>
    <unit id="unstealthiest_and_killed">
      <segment id="unstealthiest_and_killed.name" state="translated">
        <source>unstealthiest_and_killed.name</source>
        <target>Decapitated Mushroom</target>
      </segment>
      <segment id="unstealthiest_and_killed.description" state="translated">
        <source>unstealthiest_and_killed.description</source>
        <target>Stealth, but why bother? ...Well, to avoid ending up as scrambled forest eggs...</target>
      </segment>
    </unit>
  </file>
